<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>JoldiGo</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Jaldi Go requires location access to track driver routes and calculate trip distances in real-time.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Jaldi Go requires continuous location tracking in the background to ensure reliable driver dispatching and route monitoring.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Jaldi Go tracks your coordinates even when minimized to allow seamless customer pick-up updates.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Jaldi Go requires camera access to allow Driver partners to capture and upload verification documents like Driver's License and RC Books.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>JoldiGo requires microphone access to enable VoIP voice calling between riders and drivers.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Jaldi Go requires photo library access to allow uploading verification documents from your gallery.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Jaldi Go requires permissions to save captured verification images to your photos gallery.</string>
</dict>
</plist>
